{
  "expo": {
    "name": "Sugar Quit",
    "slug": "sugar-quit",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sugarquit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gazetastreet.sugarquit"
    },
    "android": {
      "package": "com.gazetastreet.sugarquit"
    },
    "plugins": [
      "expo-router",
      "expo-haptics",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
