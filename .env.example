# Sugar Quit — environment variables.
# Copy to `.env` (gitignored) and fill in. These are PUBLISHABLE keys — they
# ship in the app bundle. Never put secrets here.

# Supabase — Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — used for admin scripts / migrations. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Adapty — App Settings → API keys → Public SDK key.
# react-native-adapty is a NATIVE module — it requires an Expo dev client
# (`expo prebuild` + `eas build --profile development`). Will not work in Expo Go.
EXPO_PUBLIC_ADAPTY_PUBLIC_KEY=
